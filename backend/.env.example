# ── Backend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed origins (no spaces)
# Production example: https://primekeys.app,https://www.primekeys.app,https://primekeys.vercel.app,https://www.primekeys.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Firebase Admin ──────────────────────────────────────────────────────────
# Download from Firebase Console > Project Settings > Service Accounts > Node.js
# Paste the full JSON as a single env var (for production/Railway deployment)
FIREBASE_SERVICE_ACCOUNT=

# ── PayPal ──────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
Sandbox: https://api-m.sandbox.paypal.com  |  Production: https://api-m.paypal.com
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Wise ─────────────────────────────────────────────────────────────────────
WISE_WEBHOOK_SECRET=

# ── Admin ───────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_SECRET=
