# ── Vercel / Frontend Environment Variables ────────────────────────────────────
# Add these in: Vercel Dashboard → Your Project → Settings → Environment Variables
# NEVER commit .env.local to version control

# ── Firebase Client (safe to expose in browser) ────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCHWc7r9W6GjGcNKYhQPxPqCETnUkEcCSM
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=primekeys-ops.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=primekeys-ops
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=primekeys-ops.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=378777855555
NEXT_PUBLIC_FIREBASE_APP_ID=1:378777855555:web:3b97e7a9dd5c5590c0d6f6

# ── Firebase Admin (server-side only — DO NOT prefix with NEXT_PUBLIC_) ─────────
# Download service account from Firebase Console → Project Settings → Service Accounts
# Paste the FULL JSON as a single env var value (one long line, no newlines)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"primekeys-ops",...}

# ── Admin Secret (server-side only) ────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_SECRET=

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Sandbox: https://api-m.sandbox.paypal.com | Production: https://api-m.paypal.com
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Admin Email ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@primekeys.app

# ── Wise (optional) ────────────────────────────────────────────────────────────
WISE_WEBHOOK_SECRET=

# ── reCAPTCHA (get from Firebase Console → App Check) ─────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LfYOUR_RECAPTCHA_KEY_HERE
